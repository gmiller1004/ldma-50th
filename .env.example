# Members Phase 1 — copy to .env.local and fill in values
# See docs/MEMBERS_PHASE1_SETUP.md for details

# Site URL for emails, share links, canonical URLs, OAuth. Set to production domain when live (e.g. https://myldma.com).
# NEXT_PUBLIC_SITE_URL=https://ldma-50th.vercel.app

# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX). Omit to disable.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Salesforce (Client Credentials flow - for External Client Apps)
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_DOMAIN=gpaa.my.salesforce.com
SALESFORCE_AUTH_METHOD=client_credentials

# Only if using password flow (classic Connected Apps):
# SALESFORCE_USERNAME=
# SALESFORCE_PASSWORD=
# SALESFORCE_SECURITY_TOKEN=

# Salesforce webhook (legacy offer email)
# Generate with: openssl rand -hex 32
# SALESFORCE_WEBHOOK_SECRET=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=LDMA

# Upstash Redis (auth codes). Either use the vars below or LDMAStorage_* from Vercel/Upstash:
# LDMAStorage_KV_REST_API_URL, LDMAStorage_KV_REST_API_TOKEN (and optionally LDMAStorage_KV_URL)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Session secret: openssl rand -hex 32
MEMBER_SESSION_SECRET=

# Optional: URL for "make a payment" (appends ?amount=X). See docs/MEMBERS_MAINTENANCE_PAYMENT.md
# MEMBER_MAINTENANCE_PAYMENT_URL=

# Klaviyo (newsletter signup on homepage)
# Get from Klaviyo: Settings > API Keys > Create Private API Key (needs lists:write, profiles:write, subscriptions:write)
# KLAVIYO_PRIVATE_API_KEY=
# Optional: List ID if you want to add subscribers to a specific list (find in Klaviyo Lists). Omit to use account default.
# KLAVIYO_LIST_ID=

# Mailchimp (E-commerce cart sync for add-to-cart automations)
# API key from Mailchimp: Account > Extras > API keys (format: xxxxx-us21). Store ID from Integrations > Shopify (4-digit in URL).
# MAILCHIMP_API_KEY=
# MAILCHIMP_STORE_ID=
